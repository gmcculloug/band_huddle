<div class="gig-row">
    <div class="gig-date-badge" style="background:<%= badge_color[:bg] %>">
        <div class="badge-month"><%= gig.performance_date.strftime('%b') %></div>
        <div class="badge-day"><%= gig.performance_date.day %></div>
    </div>
    <div class="gig-card" style="box-shadow: 4px 4px 28px <%= badge_color[:glow] %>">
        <% if defined?(show_band_name) && show_band_name %>
            <div style="color: #a78bfa; font-size: 0.85rem; font-weight: 600; margin-bottom: 4px;">
                <%= h(gig.band.name) %>
            </div>
        <% end %>
        <div class="gig-name">
            <% if !gig.private_event && gig.venue&.website.present? %>
                <a href="<%= h(gig.venue.website) %>" target="_blank" rel="noopener noreferrer"><%= h(gig.name) %></a>
            <% else %>
                <%= gig.private_event ? 'Private Event' : h(gig.name) %>
            <% end %>
            <% if !gig.private_event && gig.start_time %>
                <span class="gig-name-time">
                    <span class="local-time" data-utc="<%= gig.start_time.utc.iso8601 %>"><%= gig.start_time.utc.strftime('%-I:%M %p UTC') %></span>
                    <% if gig.end_time %>
                        &ndash; <span class="local-time" data-utc="<%= gig.end_time.utc.iso8601 %>"><%= gig.end_time.utc.strftime('%-I:%M %p UTC') %></span>
                    <% end %>
                </span>
            <% end %>
        </div>
        <% unless gig.private_event %>
            <% has_tags = gig.venue&.name.present? || gig.venue&.location.present? %>
            <%
              if defined?(@band) && @band
                calendar_url = "/schedule/#{@band.slug}/gigs/#{gig.id}/calendar.ics"
              elsif defined?(@user) && @user
                calendar_url = "/members/#{@user.slug}/gigs/#{gig.id}/calendar.ics"
              else
                calendar_url = nil
              end
            %>
            <% if has_tags || calendar_url %>
                <div class="gig-tags">
                    <% if gig.venue&.name.present? || gig.venue&.location.present? %>
                        <% map_link = gig.venue.map_url.present? ? gig.venue.map_url : "https://www.google.com/maps/search/?api=1&query=#{h([gig.venue.name, gig.venue.location].compact.join(', '))}" %>
                        <a href="<%= h(map_link) %>" target="_blank" rel="noopener noreferrer" class="gig-location">📍 <%= h([gig.venue.name, gig.venue.location].compact.join(', ')) %></a>
                    <% end %>
                    <% if calendar_url %>
                        <a href="<%= calendar_url %>" class="calendar-link" download>Add to Calendar</a>
                    <% end %>
                </div>
            <% end %>
        <% end %>
    </div>
</div>
