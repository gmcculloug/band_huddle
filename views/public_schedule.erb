<div class="card">
    <div class="header">
        <h1><%= h(@band.name) %></h1>
        <p>Upcoming Shows & Performances</p>
    </div>
    
    <div class="content">
        <% if @upcoming_gigs.any? %>
            <% @upcoming_gigs.each do |gig| %>
                <div class="gig-item">
                    <div class="gig-date">
                        <div class="month"><%= gig.performance_date.strftime('%b') %></div>
                        <div class="day"><%= gig.performance_date.day %></div>
                        <div class="weekday"><%= gig.performance_date.strftime('%A') %></div>
                    </div>
                    <div class="gig-details">
                        <div class="gig-name">
                            <% if !gig.private_event && gig.venue&.website.present? %>
                                <a href="<%= h(gig.venue.website) %>" target="_blank" rel="noopener noreferrer"><%= h(gig.name) %></a>
                            <% else %>
                                <%= gig.private_event ? 'Private Event' : h(gig.name) %>
                            <% end %>
                        </div>
                        <% unless gig.private_event %>
                            <% if gig.start_time %>
                                <div class="gig-time">
                                    🕐 <span class="local-time" data-utc="<%= gig.start_time.utc.iso8601 %>"><%= gig.start_time.utc.strftime('%I:%M %p UTC') %></span>
                                    <% if gig.end_time %>
                                        - <span class="local-time" data-utc="<%= gig.end_time.utc.iso8601 %>"><%= gig.end_time.utc.strftime('%I:%M %p UTC') %></span>
                                    <% end %>
                                </div>
                            <% end %>
                            <% if gig.venue %>
                                <div class="gig-venue">
                                    📍
                                    <% unless gig.name == gig.venue.name %>
                                        <span class="venue-name"><%= h(gig.venue.name) %></span>
                                    <% end %>
                                    <% if gig.venue.location %>
                                        <% map_link = gig.venue.map_url.present? ? gig.venue.map_url : "https://www.google.com/maps/search/?api=1&query=#{h(gig.venue.location)}" %>
                                        <% separator = (gig.name == gig.venue.name) ? '' : ' — ' %>
                                        <span class="venue-location"><%= separator %><a href="<%= h(map_link) %>" target="_blank" rel="noopener noreferrer"><%= h(gig.venue.location) %></a></span>
                                    <% end %>
                                </div>
                            <% end %>
                        <% end %>
                    </div>
                </div>
            <% end %>
        <% else %>
            <div class="no-gigs">
                <div class="no-gigs-icon">🎵</div>
                <p>No upcoming shows scheduled.</p>
                <p style="font-size: 0.9rem; margin-top: 10px;">Check back soon for updates!</p>
            </div>
        <% end %>
    </div>
</div>