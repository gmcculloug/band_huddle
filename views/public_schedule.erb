<div class="card">
    <div class="header">
        <% if @band.logo_filename.present? %>
            <img src="/uploads/band_logos/<%= @band.logo_filename %>"
                 alt="<%= h(@band.name) %>"
                 fetchpriority="high"
                 style="max-height: <%= @band.show_band_name ? '200px' : '260px' %>; max-width: 90%; object-fit: contain; margin-bottom: 10px; display: block; margin-left: auto; margin-right: auto;">
            <% if @band.show_band_name %>
                <h1><%= h(@band.name) %></h1>
            <% end %>
        <% else %>
            <h1><%= h(@band.name) %></h1>
        <% end %>
        <p>Upcoming Shows &amp; Performances</p>
    </div>

    <div class="content">
        <% if @upcoming_gigs.any? %>
            <% @upcoming_gigs.each do |gig| %>
                <%= erb :_public_gig_item, locals: { gig: gig, show_band_name: false } %>
            <% end %>
        <% else %>
            <div class="no-gigs">
                <div class="no-gigs-icon">🎵</div>
                <p>No upcoming shows scheduled.</p>
                <p style="font-size: 0.9rem; margin-top: 10px;">Check back soon for updates!</p>
            </div>
        <% end %>
    </div>
</div>