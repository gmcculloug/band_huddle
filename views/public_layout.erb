<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @band ? h(@band.name) : @user ? h(@user.display_name) : 'Schedule' %> - Band Huddle</title>
    <% if @band&.logo_filename.present? %>
        <link rel="preload" as="image" href="/uploads/band_logos/<%= @band.logo_filename %>">
    <% end %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #e8e8f0;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 45%, #1a1a2e 100%);
            min-height: 100vh;
            padding: 40px 20px 60px;
        }

        /* Subtle radial glow in the background */
        body::before {
            content: '';
            position: fixed;
            top: -20%;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            height: 600px;
            background: radial-gradient(ellipse at center, rgba(123, 47, 255, 0.18) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .container {
            max-width: 860px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* Band header (logo / name) */
        .band-header {
            text-align: center;
            margin-bottom: 10px;
        }

        .band-header img {
            max-height: 120px;
            max-width: 80%;
            object-fit: contain;
            margin-bottom: 8px;
            display: block;
            margin-left: auto;
            margin-right: auto;
            filter: drop-shadow(0 4px 20px rgba(255, 255, 255, 0.18));
        }

        .band-header .band-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 4px;
            letter-spacing: 0.02em;
        }

        /* Page heading with animated gradient text */
        .page-heading {
            font-size: 3rem;
            font-weight: 900;
            text-align: center;
            background: linear-gradient(90deg, #c44d7a, #b89020, #2a9e8a, #6848c0, #c44d7a);
            background-size: 300%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 32px;
            line-height: 1.1;
            animation: gradient-shift 8s ease infinite;
        }

        @keyframes gradient-shift {
            0%   { background-position: 0% 50%; }
            50%  { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Gig row: date badge + card side by side */
        .gig-row {
            display: flex;
            align-items: stretch;
            gap: 0;
            margin-bottom: 20px;
            border-radius: 14px;
            transition: transform 0.2s ease;
        }

        .gig-row:hover {
            transform: translateY(-3px);
        }

        /* Date badge — color assigned server-side per gig */
        .gig-date-badge {
            flex-shrink: 0;
            color: white;
            border-radius: 12px 0 0 12px;
            width: 90px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 18px 10px;
        }

        .gig-date-badge .badge-month {
            font-size: 0.9rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.1em;
        }

        .gig-date-badge .badge-day {
            font-size: 2.8rem;
            font-weight: 900;
            line-height: 1;
        }

        /* Glassmorphic card */
        .gig-card {
            flex: 1;
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 22px 26px;
        }

        .gig-card .gig-name {
            font-size: 1.35rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .gig-card .gig-name a {
            color: inherit;
            text-decoration: none;
            transition: color 0.15s;
        }

        .gig-card .gig-name a:hover {
            color: #ffd700;
        }

        .gig-name-time {
            font-size: 0.9rem;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.55);
            margin-left: 10px;
            white-space: nowrap;
        }

        .gig-card .gig-datetime {
            font-size: 0.95rem;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.65);
            margin-bottom: 12px;
        }

        .gig-card .gig-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }

        .gig-location {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: color 0.15s;
        }

        .gig-location:hover {
            color: #ffd700;
        }

        .gig-tag {
            background: rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.75);
            font-size: 0.82rem;
            font-weight: 500;
            padding: 5px 14px;
            border-radius: 999px;
        }

        .calendar-link {
            display: inline-block;
            color: #ffd700;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 999px;
            border: 1px solid #ffd700;
            transition: background 0.15s, color 0.15s;
        }

        .calendar-link:hover {
            background: #ffd700;
            color: #0f0c29;
        }

        .no-gigs {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.8);
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
        }

        .no-gigs-icon {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .powered-by {
            text-align: center;
            margin-top: 40px;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.35);
        }

        .powered-by a {
            color: rgba(255, 255, 255, 0.55);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.15s;
        }

        .powered-by a:hover {
            color: #ffd700;
        }

        @media (max-width: 600px) {
            .page-heading {
                font-size: 2.2rem;
            }

            .gig-date-badge {
                width: 70px;
                padding: 14px 8px;
            }

            .gig-date-badge .badge-day {
                font-size: 2rem;
            }

            .gig-card {
                padding: 16px 18px;
            }

            .gig-card .gig-name {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <%= yield %>
        <div class="powered-by">
            Powered by <a href="/">Band Huddle</a>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.local-time').forEach(function(el) {
                var d = new Date(el.dataset.utc);
                el.textContent = d.toLocaleTimeString('en-US', {
                    hour: 'numeric', minute: '2-digit', timeZoneName: 'short'
                });
            });
        });
    </script>
</body>
</html>
