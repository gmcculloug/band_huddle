<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @band ? h(@band.name) : @user ? h(@user.display_name) : 'Schedule' %> - Band Huddle</title>
    <% if @band&.logo_filename.present? %>
        <link rel="preload" as="image" href="/uploads/band_logos/<%= @band.logo_filename %>">
    <% end %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            line-height: 1.6;
            color: #333;
            background: #b8cdd5;
            min-height: 100vh;
            padding: 40px 20px 60px;
        }

        .container {
            max-width: 860px;
            margin: 0 auto;
        }

        /* Band header (logo / name) */
        .band-header {
            text-align: center;
            margin-bottom: 10px;
        }

        .band-header img {
            max-height: 120px;
            max-width: 80%;
            object-fit: contain;
            margin-bottom: 8px;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }

        .band-header .band-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1a3a45;
            margin-bottom: 4px;
        }

        /* Page heading */
        .page-heading {
            font-size: 3rem;
            font-weight: 800;
            color: #1a3a45;
            margin-bottom: 30px;
            line-height: 1.1;
        }

        /* Gig row: date badge + card side by side */
        .gig-row {
            display: flex;
            align-items: stretch;
            gap: 0;
            margin-bottom: 20px;
        }

        .gig-date-badge {
            flex-shrink: 0;
            background: #1a3a45;
            color: white;
            border-radius: 10px 0 0 10px;
            width: 90px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 18px 10px;
        }

        .gig-date-badge .badge-month {
            font-size: 1rem;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.08em;
            opacity: 0.85;
        }

        .gig-date-badge .badge-day {
            font-size: 2.8rem;
            font-weight: 800;
            line-height: 1;
        }

        .gig-card {
            flex: 1;
            background: white;
            border-radius: 0 12px 12px 0;
            padding: 22px 26px;
            box-shadow: 2px 4px 16px rgba(0, 0, 0, 0.08);
        }

        .gig-card .gig-name {
            font-size: 1.35rem;
            font-weight: 700;
            color: #1a3a45;
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .gig-card .gig-name a {
            color: inherit;
            text-decoration: none;
        }

        .gig-card .gig-name a:hover {
            text-decoration: underline;
        }

        .gig-name-time {
            font-size: 0.9rem;
            font-weight: 500;
            color: #4a6a78;
            margin-left: 10px;
            white-space: nowrap;
        }

        .gig-card .gig-datetime {
            font-size: 0.95rem;
            font-weight: 500;
            color: #2d4a55;
            margin-bottom: 12px;
        }

        .gig-card .gig-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }

        .gig-location {
            font-size: 0.9rem;
            color: #4a6a78;
            text-decoration: none;
        }

        .gig-location:hover {
            text-decoration: underline;
        }

        .gig-tag {
            background: #e8edf0;
            color: #3a5a68;
            font-size: 0.82rem;
            font-weight: 500;
            padding: 5px 14px;
            border-radius: 999px;
        }

        .calendar-link {
            display: inline-block;
            color: #3a7a9c;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 500;
            padding: 5px 14px;
            border-radius: 999px;
            border: 1px solid #3a7a9c;
            transition: background 0.15s, color 0.15s;
        }

        .calendar-link:hover {
            background: #3a7a9c;
            color: white;
        }

        .no-gigs {
            text-align: center;
            padding: 60px 20px;
            color: #1a3a45;
            background: white;
            border-radius: 12px;
            box-shadow: 2px 4px 16px rgba(0, 0, 0, 0.08);
        }

        .no-gigs-icon {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .powered-by {
            text-align: center;
            margin-top: 40px;
            font-size: 0.85rem;
            color: #4a6a78;
        }

        .powered-by a {
            color: #1a3a45;
            text-decoration: none;
            font-weight: 600;
        }

        .powered-by a:hover {
            text-decoration: underline;
        }

        @media (max-width: 600px) {
            .page-heading {
                font-size: 2.2rem;
            }

            .gig-date-badge {
                width: 70px;
                padding: 14px 8px;
            }

            .gig-date-badge .badge-day {
                font-size: 2rem;
            }

            .gig-card {
                padding: 16px 18px;
            }

            .gig-card .gig-name {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <%= yield %>
        <div class="powered-by">
            Powered by <a href="/">Band Huddle</a>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.local-time').forEach(function(el) {
                var d = new Date(el.dataset.utc);
                el.textContent = d.toLocaleTimeString('en-US', {
                    hour: 'numeric', minute: '2-digit', timeZoneName: 'short'
                });
            });
        });
    </script>
</body>
</html>
